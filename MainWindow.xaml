<Window x:Class="Visunovia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Visunovia.Controls"
        Title="Visunovia" Height="720" Width="1280"
        Background="#0D0D0D"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#1A1A1A">
            <MenuItem Header="文件" Foreground="White">
                <MenuItem Header="新建项目 (Ctrl+N)" Click="OnNewProjectClicked"/>
                <MenuItem Header="快速创建项目 (Ctrl+Shift+N)" Click="OnQuickNewProjectClicked"/>
                <MenuItem Header="打开项目 (Ctrl+O)" Click="OnOpenProjectClicked"/>
                <MenuItem Header="保存项目 (Ctrl+S)" Click="OnSaveProjectClicked"/>
                <Separator/>
                <MenuItem Header="打包项目 (Ctrl+B)" Click="OnPackageProjectClicked"/>
            </MenuItem>
            <MenuItem Header="编辑" Foreground="White">
                <MenuItem Header="撤销 (Ctrl+Z)" Click="OnUndoClicked"/>
                <MenuItem Header="重做 (Ctrl+Y)" Click="OnRedoClicked"/>
            </MenuItem>
            <MenuItem Header="设置" Foreground="White">
                <MenuItem Header="引擎设置..." Click="OnSettingsClicked"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="0" Background="#141414">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0">
                <TextBlock Text="Visunovia" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="ProjectNameLabel" Grid.Column="1" Text="未命名项目" FontSize="12" Foreground="#999999" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                <Button Content="撤销" Style="{StaticResource ToolbarButton}" Click="OnUndoClicked"/>
                <Button Content="重做" Style="{StaticResource ToolbarButton}" Click="OnRedoClicked"/>
                <Button Content="新建" Style="{StaticResource ToolbarButton}" Click="OnNewProjectClicked"/>
                <Button Content="快速创建" Style="{StaticResource ToolbarButton}" Click="OnQuickNewProjectClicked"/>
                <Button Content="打开" Style="{StaticResource ToolbarButton}" Click="OnOpenProjectClicked"/>
                <Button Content="保存" Style="{StaticResource ToolbarButton}" Click="OnSaveProjectClicked"/>
                <Button Content="运行" Style="{StaticResource AccentButton}" Click="OnRunProjectClicked"/>
                <Button x:Name="StopPreviewBtn" Content="停止" Style="{StaticResource ToolbarButton}" Click="OnStopPreviewClicked" Visibility="Collapsed"/>
                <Button x:Name="PackageProjectBtn" Content="打包" Background="#10B981" Foreground="White" Click="OnPackageProjectClicked"/>
                <Button Content="从选中预览" Background="#8057D4" Foreground="White" Click="OnPreviewFromSelectedClicked"/>
                <Button Content="设置" Style="{StaticResource ToolbarButton}" Click="OnSettingsClicked"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="#141414">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1A1A1A">
                    <TextBlock Text="资源" FontSize="11" FontWeight="Bold" Foreground="#666666" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <controls:ResourceManagerControl x:Name="ResourceManager" Grid.Row="1"/>

            </Grid>

            <Grid Grid.Column="1" Background="#0D0D0D">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1A1A1A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer Grid.Row="0" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="SceneTabsContainer" Orientation="Horizontal" Margin="8,8,8,0"/>
                    </ScrollViewer>
                    <Button Grid.Row="0" Grid.Column="1" Content="+ 添加场景" Click="OnAddSceneClicked"
                            Margin="0,8,8,0" Padding="10,4"
                            Background="#10B981" Foreground="White" BorderThickness="0"
                            FontSize="11" Cursor="Hand"/>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="8,4,8,4">
                        <Button Content="+ 添加对话" Click="OnAddDialogueClicked"
                                Padding="8,4" Background="#3B82F6" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                        <Button Content="+ 添加分支" Click="OnAddBranchClicked"
                                Margin="4,0,0,0" Padding="8,4" Background="#10B981" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                        <Button Content="+ 添加事件" Click="OnAddEventClicked"
                                Margin="4,0,0,0" Padding="8,4" Background="#F59E0B" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                        <Button Content="复制对话" Click="OnCopyDialogueClicked"
                                Margin="4,0,0,0" Padding="8,4" Background="#6B7280" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                        <Button Content="删除对话" Click="OnDeleteDialogueClicked"
                                Margin="4,0,0,0" Padding="8,4" Background="#EF4444" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                        <Button Content="上移" Click="OnMoveUpClicked"
                                Margin="4,0,0,0" Padding="8,4" Background="#3B82F6" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                        <Button Content="下移" Click="OnMoveDownClicked"
                                Margin="4,0,0,0" Padding="8,4" Background="#3B82F6" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <TabControl x:Name="EditorTabControl" Grid.Row="2"
                            Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Setter Property="Foreground" Value="#888888"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="TabBorder"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent"
                                                Cursor="Hand">
                                            <ContentPresenter ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#3B82F6"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#252525"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="对话列表">
                        <ScrollViewer x:Name="DialogueScrollView" Margin="12" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="DialogueListContainer"/>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <Grid Grid.Column="2" Background="#141414">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1A1A1A">
                    <TextBlock x:Name="PropertyPanelTitle" Text="属性面板" FontSize="11" FontWeight="Bold" Foreground="#666666" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <Grid x:Name="PropertyPanelGrid" Grid.Row="1">
                    <ScrollViewer x:Name="PropertyScrollViewer" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PropertyPanelContainer" Margin="12"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Background="#141414">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="就绪" FontSize="11" Foreground="#666666" Margin="12,0,0,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="SaveStatusLabel" Grid.Column="1" Text="" FontSize="11" Foreground="#999999" Margin="0,0,12,0" VerticalAlignment="Center"/>
        </Grid>

        <controls:DebugPanel x:Name="DebugConsoleControl" Grid.Row="1" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10"/>

        <Grid x:Name="PreviewOverlay" Grid.RowSpan="3" Background="#F0000000" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <controls:PreviewControl x:Name="PreviewControl" Grid.Row="0"/>
        </Grid>
    </Grid>
</Window>
