<UserControl x:Class="Visunovia.Player.WPF.UI.DialoguePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="180"
             VerticalAlignment="Bottom">
    <UserControl.Resources>
        <Style x:Key="SpeakerTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Margin" Value="20,0,0,8"/>
        </Style>
        <Style x:Key="DialogueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="20,0,20,10"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#CC1A1A1A" CornerRadius="8" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="SpeakerText" 
                       Grid.Row="0" 
                       Style="{StaticResource SpeakerTextStyle}"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DialogueTextBlock"
                           Style="{StaticResource DialogueTextStyle}"/>
            </ScrollViewer>

            <TextBlock Grid.Row="1" 
                       Text="▼ 点击继续" 
                       FontSize="10" 
                       Foreground="#666666" 
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Bottom" 
                       Margin="0,0,20,5"/>
        </Grid>
    </Border>
</UserControl>