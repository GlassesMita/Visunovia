<Window x:Class="Visunovia.Player.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Visunovia.Player.WPF.UI"
        Title="Visunovia Player" 
        Height="720" Width="1280"
        Background="#0D0D0D"
        WindowStartupLocation="CenterScreen"
        KeyDown="OnKeyDown"
        MouseDown="OnMouseDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Image x:Name="BackgroundImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
            <Canvas x:Name="CharacterCanvas"/>
            <MediaElement x:Name="BgmPlayer"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"/>
        </Grid>

        <ui:ChoicePanel x:Name="ChoicePanelControl" 
                        Grid.Row="0" 
                        Visibility="Collapsed"/>

        <Grid Grid.Row="1" Background="#1A1A1A" Height="4">
            <ProgressBar x:Name="LoadingProgress" 
                         Minimum="0" Maximum="100" 
                         Value="0"
                         Background="#333333" 
                         Foreground="#3B82F6"
                         BorderThickness="0"/>
        </Grid>

        <ui:DialoguePanel x:Name="DialoguePanelControl" 
                         Grid.Row="2"
                         Visibility="Collapsed"/>

        <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#0D0D0D">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="正在加载..." 
                           FontSize="24" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <ProgressBar x:Name="LoadingBar" 
                             Minimum="0" Maximum="100" 
                             Value="0"
                             Width="300" 
                             Height="8" 
                             Margin="0,20,0,0"
                             Background="#333333" 
                             Foreground="#3B82F6"
                             BorderThickness="0"/>
                <TextBlock x:Name="LoadingText" 
                           Text="" 
                           FontSize="12" 
                           Foreground="#999999"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="ErrorOverlay" Grid.RowSpan="3" Background="#0D0D0D" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="加载失败" 
                           FontSize="24" 
                           Foreground="#EF4444"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" 
                           Text="" 
                           FontSize="14" 
                           Foreground="#999999"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <Button Content="关闭" 
                        Click="OnCloseClicked"
                        Margin="0,20,0,0"
                        Padding="20,10"
                        Background="#EF4444"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>