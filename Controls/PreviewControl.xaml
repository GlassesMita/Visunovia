<UserControl x:Class="Visunovia.Controls.PreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <MediaElement x:Name="BgmPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Visibility="Collapsed"/>
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Grid.RowSpan="2"/>
        <Image x:Name="CharacterImage" Stretch="Uniform" Grid.RowSpan="2"
               VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        <Border x:Name="DialogueBox" Grid.Row="1" Background="#CC000000"
                Padding="20" Margin="20" CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="SpeakerLabel" FontWeight="Bold" FontSize="18"
                           Foreground="White" Margin="0,0,0,8"/>
                <TextBlock x:Name="DialogueLabel" FontSize="16" Foreground="White"
                           TextWrapping="Wrap" MaxHeight="100"/>
                <TextBlock Text="▼" Foreground="#3B82F6" HorizontalAlignment="Right"
                           Margin="0,8,0,0" FontSize="12"/>
            </StackPanel>
        </Border>
        <Border x:Name="ChoicesPanel" Grid.Row="1" Background="#CC000000"
                Padding="30" Margin="20" CornerRadius="8"
                Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel x:Name="ChoicesContainer"/>
        </Border>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Top" Margin="10">
            <Button Content="❌" FontSize="16" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Click="OnCloseClicked"/>
            <Button Content="⛶" FontSize="16" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="OnFullscreenClicked"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <Button Content="⏮️ 上一个" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Click="OnPreviousClicked"/>
            <Button Content="下一个 ⏭️" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Margin="10,0,0,0" Click="OnNextClicked"/>
        </StackPanel>
    </Grid>
</UserControl>
