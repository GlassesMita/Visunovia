<UserControl x:Class="Visunovia.Controls.PreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black">
    <UserControl.Resources>
        <Style x:Key="SpeakerTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Margin" Value="20,0,0,8"/>
        </Style>
        <Style x:Key="DialogueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="20,0,20,10"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <MediaElement x:Name="BgmPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                      Visibility="Collapsed"/>
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Grid.RowSpan="2"/>
        <Image x:Name="CharacterImage" Stretch="Uniform" Grid.RowSpan="2"
               VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        <Border x:Name="DialogueBox" Grid.Row="1" Background="#CC1A1A1A"
                Padding="0" Margin="10" CornerRadius="8"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="SpeakerLabel"
                           Grid.Row="0"
                           Style="{StaticResource SpeakerTextStyle}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DialogueLabel"
                               Style="{StaticResource DialogueTextStyle}"/>
                </ScrollViewer>

                <TextBlock Grid.Row="1"
                           Text="▼ 点击继续"
                           FontSize="10"
                           Foreground="#666666"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,20,5"/>
            </Grid>
        </Border>
        <Border x:Name="ChoicesPanel" Grid.Row="1" Background="#CC1A1A1A"
                Padding="30" Margin="20" CornerRadius="8"
                Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel x:Name="ChoicesContainer"/>
        </Border>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Top" Margin="10">
            <Button Content="❌" FontSize="16" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Click="OnCloseClicked"/>
            <Button Content="⛶" FontSize="16" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="OnFullscreenClicked"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <Button Content="⏮️ 上一个" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Click="OnPreviousClicked"/>
            <Button Content="下一个 ⏭️" Padding="10,5" Background="#80000000"
                    Foreground="White" BorderThickness="0" Margin="10,0,0,0" Click="OnNextClicked"/>
        </StackPanel>
    </Grid>
</UserControl>
