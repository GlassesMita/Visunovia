<UserControl x:Class="Visunovia.Controls.ResourceManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#141414">
        <TabControl x:Name="ResourceTabs" Background="Transparent" BorderThickness="0">
            <TabItem Header="立绘">
                <ListBox x:Name="SpritesList" Background="Transparent" BorderThickness="0"
                         AllowDrop="False" PreviewMouseMove="OnSpriteMouseMove"
                         Drop="OnSpriteDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
                         MouseDoubleClick="OnResourceDoubleClicked">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="4,2">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding ThumbnailPath}" Width="32" Height="32"
                                           Stretch="UniformToFill" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="背景">
                <ListBox x:Name="BackgroundsList" Background="Transparent" BorderThickness="0"
                         AllowDrop="False" PreviewMouseMove="OnBackgroundMouseMove"
                         Drop="OnBackgroundDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
                         MouseDoubleClick="OnResourceDoubleClicked">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="4,2">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding ThumbnailPath}" Width="32" Height="32"
                                           Stretch="UniformToFill" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="音乐">
                <ListBox x:Name="MusicsList" Background="Transparent" BorderThickness="0"
                         AllowDrop="False" PreviewMouseMove="OnMusicMouseMove"
                         Drop="OnMusicDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
                         MouseDoubleClick="OnResourceDoubleClicked">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="4,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎵" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="语音">
                <ListBox x:Name="VoicesList" Background="Transparent" BorderThickness="0"
                         AllowDrop="False" PreviewMouseMove="OnVoiceMouseMove"
                         Drop="OnVoiceDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
                         MouseDoubleClick="OnResourceDoubleClicked">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="4,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎤" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="字体">
                <ListBox x:Name="FontsList" Background="Transparent" BorderThickness="0"
                         AllowDrop="False" PreviewMouseMove="OnFontMouseMove"
                         Drop="OnFontDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
                         MouseDoubleClick="OnResourceDoubleClicked">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="4,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔤" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="其他">
                <ListBox x:Name="OthersList" Background="Transparent" BorderThickness="0"
                         AllowDrop="False" PreviewMouseMove="OnOtherMouseMove"
                         Drop="OnOtherDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
                         MouseDoubleClick="OnResourceDoubleClicked">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="4,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                               VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>

        <Border x:Name="AddResourceButton" Background="#1A1A1A"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="8" Padding="8,4" CornerRadius="4" Cursor="Hand"
                MouseLeftButtonUp="OnAddResourceClicked">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="+" Foreground="#3B82F6" FontSize="16" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Text="添加" Foreground="#3B82F6" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
