<UserControl x:Class="Visunovia.Controls.DebugPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#1A1A1A" BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2D2D2D" Padding="10,5" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="控制台"
                               FontSize="12" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="清空" Click="ClearButton_Click"
                                FontSize="11" Padding="10,5"
                                Background="#3D3D3D" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,0,5,0"/>
                        <Button Content="▼" x:Name="ToggleButton" Click="ToggleButton_Click"
                                FontSize="11" Padding="10,5"
                                Background="#3D3D3D" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="200">
                <ItemsControl x:Name="LogItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="5,2" Background="Transparent">
                                <TextBlock Text="{Binding FormattedMessage}"
                                           FontSize="11" Foreground="{Binding LevelBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#2D2D2D" Padding="5,3">
                <CheckBox Content="自动滚动"
                          x:Name="AutoScrollCheckBox"
                          IsChecked="True"
                          Foreground="White"
                          FontSize="11"
                          VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
